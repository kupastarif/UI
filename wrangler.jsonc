{
  "$schema": "https://json.schemastore.org/wrangler.json",
  "name": "ojol",
  "compatibility_date": "2026-07-21",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": ["node_modules/**/*", ".git/**/*", ".github/**/*", "android/**/*", "ios/**/*", "*.apk", "*.aab"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
